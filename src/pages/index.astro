---
import PageLayout from '../layouts/PageLayout.astro';
import { indexPage } from '../data/indexPage';
import HomeHero from '../components/HomeHero.astro';
import FAQ from '../components/FAQ.astro';
import Features from '../components/Features.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';

const { seo, hero, services, features, testimonials, faq } = indexPage;
---

<PageLayout seo={seo}>
  <!-- 1. ATTENTION: The "Hero" hooks the user immediately -->
  <HomeHero data={hero} />

  <!-- 2. INTEREST: Show your core offerings immediately to reduce bounce rate -->
  <Services services={services} />

  <!-- 3. AUTHORITY: Why choose you over a general contractor? (C-39 License, etc) -->
  <Features features={features} />

  <!-- 4. SOCIAL PROOF: Desire is built through the success of others -->
  <Testimonials items={testimonials} />

  <!-- 5. OBJECTIONS: Answer the final hurdles (Cost, Licenses, Emergency repairs) -->
  <FAQ faq={faq} />

  <!-- 6. ACTION: The final bridge to the conversion -->
  <section
    class="py-20 text-center bg-primary text-primary-content rounded-sm my-20 px-8 mx-4 lg:mx-auto max-w-7xl"
  >
    <h2 class="text-4xl font-bold font-heading mb-6 uppercase tracking-tight">
      Ready to Protect Your Structure?
    </h2>
    <p class="text-xl mb-10 max-w-2xl mx-auto opacity-90">
      Contact our licensed experts today for a comprehensive inspection and
      professional waterproofing recommendations.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="tel:+19498171865"
        class="btn btn-secondary btn-lg rounded-sm"
        aria-label="Call SPL Waterproofing at (949) 817-1865"
      >
        Call (949) 817-1865
      </a>
      <a
        href="/contact/"
        class="btn btn-outline btn-lg rounded-sm text-primary-content border-primary-content hover:bg-primary-content hover:text-primary"
        aria-label="Request a free waterproofing quote"
      >
        Request a Quote
      </a>
    </div>
  </section>
</PageLayout>