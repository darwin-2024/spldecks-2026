---
// src/pages/[...404].astro
export const prerender = true;

export function getStaticPaths() {
  // This tells Astro to generate a single catch-all page
  // The 'undefined' slug matches the root level 404
  return [{ params: { '404': undefined } }];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/services/" />
    <link rel="canonical" href="https://spldecks.com/services/" />
    <title>Redirecting to SPL Decks Services</title>
    <style>
      body {
        font-family: sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        color: #444;
      }
      a {
        color: #c2410c;
        text-decoration: none;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <p>Redirecting you to our <a href="/services/">services page</a>...</p>
  </body>
</html>
