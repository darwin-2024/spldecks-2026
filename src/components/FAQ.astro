---
// Props interface
export interface FAQItem {
  question: string;
  answer: string;
}

interface FAQProps {
  faq: FAQItem[];
  title?: string;
  description?: string;
}

const { 
  faq = [], 
  title = "Frequently Asked Questions", 
  description = "Get answers to common questions about our waterproofing services." 
} = Astro.props as FAQProps;
---

<section class="my-16">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Left Side: Header -->
      <div class="flex flex-col justify-start">
        <h2 class="text-3xl font-bold text-neutral uppercase tracking-tight">
          {title}
        </h2>
        <div class="mt-4 h-1 w-12 bg-accent"></div>
        <p class="mt-6 text-base-content/70 max-w-lg leading-relaxed">
          {description}
        </p>
      </div>

      <!-- Right Side: Accordion -->
      <div class="space-y-3">
        {
          faq.map((item) => (
            <details class="group collapse collapse-arrow bg-base-200/50 border border-base-300 rounded-sm">
              <summary class="collapse-title text-lg font-semibold cursor-pointer list-none flex justify-between items-center group-open:text-primary transition-colors">
                {item.question}
              </summary>
              <div class="collapse-content">
                <div class="pt-2 pb-4 text-base-content/80 leading-relaxed border-t border-base-300/50 mt-2">
                  <p class="max-w-[90%]">{item.answer}</p>
                </div>
              </div>
            </details>
          ))
        }
      </div>

    </div>
  </div>
</section>

<style>
  /* Removes the default disclosure triangle in Chrome/Safari/Firefox */
  summary::-webkit-details-marker {
    display: none;
  }
</style>