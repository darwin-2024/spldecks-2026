---
// src/components/Hero.astro
import { Image } from 'astro:assets';

interface Props {
  data: {
    title: string;
    description: string;
    heroImage: any;
    heroAlt: string;
  };
}

const { data } = Astro.props;
---

<section
  class="relative w-full bg-neutral overflow-hidden border-b border-base-300"
>
  <div class="flex flex-col lg:flex-row min-h-[70vh]">
    <!-- Text Content Area -->
    <div
      class="w-full lg:w-1/2 flex items-center justify-center p-8 md:p-16 lg:p-24 bg-base-100 z-10"
    >
      <div class="max-w-xl">
        <div
          class="inline-block px-3 py-1 mb-6 text-xs font-bold tracking-widest text-primary uppercase bg-primary/10 rounded-sm"
        >
          Professional Waterproofing
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-base-content leading-[1.1] mb-6"
        >
          {data.title}
        </h1>
        <p
          class="text-lg md:text-xl text-base-content/70 leading-relaxed mb-10 border-l-4 border-accent pl-6"
        >
          {data.description}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact/"
            class="btn btn-primary btn-lg rounded-sm px-8 shadow-lg shadow-primary/20"
            aria-label={`Schedule an inspection for ${data.title}`}
          >
            Schedule an Inspection
          </a>
        </div>
      </div>
    </div>

    <!-- Visual Area: Clean Edge -->
    <div class="w-full lg:w-1/2 relative min-h-100 lg:min-h-full">
      <!-- REMOVED: Gradient blur div was here -->
      <Image
        src={data.heroImage}
        alt={data.heroAlt}
        class="absolute inset-0 w-full h-full object-cover grayscale-20 hover:grayscale-0 transition-all duration-700"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Keeping the mobile overlay for text contrast if text wraps over image on small screens -->
      <div class="absolute inset-0 bg-black/5 lg:hidden"></div>
    </div>
  </div>
</section>
