---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  brands: Array<{ name: string; src: any }>;
}

const { title, brands } = Astro.props;
---

<section class="py-12 bg-base-100 border-y border-base-300 overflow-hidden">
  <div class="container mx-auto px-4 mb-8 text-center">
    <p class="text-xs font-bold text-base-content/40 uppercase tracking-[0.3em]">
      {title}
    </p>
  </div>

  <!-- The wrapper needs to be a flex container to keep tracks side-by-side -->
  <div class="relative flex overflow-hidden group py-4">
    <!-- 
      Track 1 & 2
      The key is to have NO absolute positioning on the second track. 
      Instead, let them sit naturally side-by-side in a flex row.
    -->
    <div class="flex animate-marquee whitespace-nowrap">
      {/* Track Content */}
      <div class="flex items-center">
        {brands.map(brand => (
          <div class="w-40 md:w-60 flex items-center justify-center px-8 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
            <Image 
              src={brand.src} 
              alt={brand.name} 
              class="h-10 md:h-12 w-auto object-contain"
            />
          </div>
        ))}
      </div>
      
      {/* Duplicate Track Content for seamless loop */}
      <div class="flex items-center" aria-hidden="true">
        {brands.map(brand => (
          <div class="w-40 md:w-60 flex items-center justify-center px-8 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
            <Image 
              src={brand.src} 
              alt={brand.name} 
              class="h-10 md:h-12 w-auto object-contain"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* 
     We animate the container holding BOTH sets of images.
     Since it contains two identical sets, moving it -50% 
     brings the start of the second set to the exact position 
     where the first set started.
  */
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee {
    display: flex;
    width: max-content; /* Critical: allows the div to expand past 100% width */
    animation: marquee 40s linear infinite;
  }

  .group:hover .animate-marquee {
    animation-play-state: paused;
  }
</style>